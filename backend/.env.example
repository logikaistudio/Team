# Server Configuration
PORT=4000
NODE_ENV=development

# Database Configuration (PostgreSQL)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=epcs_local

# Security Configuration
JWT_SECRET=super_secret_jwt_access_token_key_change_me
JWT_REFRESH_SECRET=super_secret_jwt_refresh_token_key_change_me
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# AWS S3 / Compatible Object Storage
S3_ENDPOINT=https://your-s3-compatible-storage.com
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_NAME=epcs-assets

# External Services
WHATSAPP_API_URL=https://api.whatsapp-provider.com/send
WHATSAPP_API_TOKEN=your_whatsapp_token
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@epcs-saas.com

# AI Provider API Keys
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key
