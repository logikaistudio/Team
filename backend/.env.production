# Production environment variables for Vercel deployment
# Copy these values into Vercel Dashboard → Project Settings → Environment Variables

# Server
PORT=8081
NODE_ENV=production

# Supabase Database
DATABASE_URL=postgresql://postgres:p3h03lw4hyud1@db.oxqkukvavlqpyjdbprde.supabase.co:5432/postgres
DB_HOST=db.oxqkukvavlqpyjdbprde.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=p3h03lw4hyud1
DB_NAME=postgres
DB_SSL=true

# JWT Secrets (generate strong random strings, e.g. from https://generate-secret.vercel.app/32)
JWT_SECRET=change_this_to_a_strong_random_secret
JWT_REFRESH_SECRET=change_this_to_another_strong_random_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google OAuth (optional)
